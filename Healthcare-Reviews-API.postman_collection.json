{
  "info": {
    "name": "Healthcare System - Reviews API",
    "description": "Complete Reviews API Collection with all endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "REVIEWS ENDPOINTS",
      "item": [
        {
          "name": "1. Create Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"rating\": 5,\n  \"comment\": \"Excellent doctor, very professional and caring. Highly recommended!\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews"]
            }
          }
        },
        {
          "name": "2. Get All Reviews (with filters)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews?doctorId=&status=active&page=1&limit=10&sortBy=createdAt&sortOrder=-1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews"],
              "query": [
                {
                  "key": "doctorId",
                  "value": "",
                  "disabled": false
                },
                {
                  "key": "status",
                  "value": "active",
                  "disabled": false
                },
                {
                  "key": "rating",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "10",
                  "disabled": false
                },
                {
                  "key": "sortBy",
                  "value": "createdAt",
                  "disabled": false
                },
                {
                  "key": "sortOrder",
                  "value": "-1",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "3. Get Doctor Reviews",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews/doctor/{{doctorId}}?page=1&limit=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews", "doctor", "{{doctorId}}"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "10",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "4. Get Doctor Rating Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews/doctor/{{doctorId}}/rating",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews", "doctor", "{{doctorId}}", "rating"]
            }
          }
        },
        {
          "name": "5. Get Review by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews/{{reviewId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews", "{{reviewId}}"]
            }
          }
        },
        {
          "name": "6. Update Review",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"comment\": \"Updated comment - Still excellent service!\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews/{{reviewId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews", "{{reviewId}}"]
            }
          }
        },
        {
          "name": "7. Mark Review as Helpful",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews/{{reviewId}}/helpful",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews", "{{reviewId}}", "helpful"]
            }
          }
        },
        {
          "name": "8. Unmark Review as Helpful",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews/{{reviewId}}/helpful",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews", "{{reviewId}}", "helpful"]
            }
          }
        },
        {
          "name": "9. Get Top Reviewed Doctors",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews/top/doctors?limit=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews", "top", "doctors"],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "10. Delete Review",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews/{{reviewId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews", "{{reviewId}}"]
            }
          }
        },
        {
          "name": "11. Flag Review (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adminNotes\": \"Inappropriate language detected\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/reviews/{{reviewId}}/flag",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "reviews", "{{reviewId}}", "flag"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "patientToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "doctorToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "doctorId",
      "value": "",
      "type": "string"
    },
    {
      "key": "patientId",
      "value": "",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "reviewId",
      "value": "",
      "type": "string"
    }
  ]
}
