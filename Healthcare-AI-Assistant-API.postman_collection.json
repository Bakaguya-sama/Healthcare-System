{
  "info": {
    "name": "Healthcare AI Assistant API",
    "description": "Complete AI Assistant Module API testing collection for Healthcare System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Start Conversation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"symptom_analysis\",\n  \"initialQuestion\": \"Tôi bị đau đầu kéo dài 3 ngày, đi kèm với sốt nhẹ. Đây có phải là dấu hiệu của bệnh gì?\",\n  \"tags\": [\"headache\", \"fever\", \"urgent\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations/start",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations", "start"]
        }
      },
      "response": []
    },
    {
      "name": "2. Send Message to AI",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Huyết áp của tôi là 140/90. Đây có nguy hiểm không?\",\n  \"conversationType\": \"health_inquiry\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations/{{conversationId}}/message",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations", "{{conversationId}}", "message"]
        }
      },
      "response": []
    },
    {
      "name": "3. Get All Conversations",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations?page=1&limit=20&type=&status=&isFavorite=&sortBy=createdAt&sortOrder=-1",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "type",
              "value": "",
              "disabled": true
            },
            {
              "key": "status",
              "value": "",
              "disabled": true
            },
            {
              "key": "isFavorite",
              "value": "",
              "disabled": true
            },
            {
              "key": "sortBy",
              "value": "createdAt"
            },
            {
              "key": "sortOrder",
              "value": "-1"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Get Single Conversation",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations/{{conversationId}}",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations", "{{conversationId}}"]
        }
      },
      "response": []
    },
    {
      "name": "5. Toggle Favorite",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations/{{conversationId}}/favorite",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations", "{{conversationId}}", "favorite"]
        }
      },
      "response": []
    },
    {
      "name": "6. Archive Conversation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"isArchived\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations/{{conversationId}}/archive",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations", "{{conversationId}}", "archive"]
        }
      },
      "response": []
    },
    {
      "name": "7. Rate Conversation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Very helpful and informative response from AI\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations/{{conversationId}}/rate",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations", "{{conversationId}}", "rate"]
        }
      },
      "response": []
    },
    {
      "name": "8. Update Conversation",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"topic\": \"Updated conversation topic\",\n  \"internalNotes\": \"Follow up with doctor appointment\",\n  \"tags\": [\"urgent\", \"follow-up\"],\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations/{{conversationId}}",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations", "{{conversationId}}"]
        }
      },
      "response": []
    },
    {
      "name": "9. Delete Conversation",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations/{{conversationId}}",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations", "{{conversationId}}"]
        }
      },
      "response": []
    },
    {
      "name": "10. Get Conversation Statistics",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/conversations/{{conversationId}}/stats",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "conversations", "{{conversationId}}", "stats"]
        }
      },
      "response": []
    },
    {
      "name": "11. Get User Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/summary",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "summary"]
        }
      },
      "response": []
    },
    {
      "name": "12. Search Conversations",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/ai-assistant/search?q=headache&page=1&limit=20&sortBy=createdAt&sortOrder=-1",
          "host": ["{{baseUrl}}"],
          "path": ["ai-assistant", "search"],
          "query": [
            {
              "key": "q",
              "value": "headache"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "sortBy",
              "value": "createdAt"
            },
            {
              "key": "sortOrder",
              "value": "-1"
            }
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "conversationId",
      "value": "",
      "type": "string"
    }
  ]
}
