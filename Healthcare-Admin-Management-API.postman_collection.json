{
  "info": {
    "name": "Healthcare Admin Management API",
    "description": "API collection for Admin features: Doctor Verification, Account Lock/Unlock, Violation Management, Sessions Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🩺 Doctor Verification",
      "item": [
        {
          "name": "1. Get Pending Doctors",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/doctors/pending",
              "host": ["{{base_url}}"],
              "path": ["admin", "doctors", "pending"]
            }
          },
          "response": []
        },
        {
          "name": "2. Verify Doctor (Approve)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verificationNotes\": \"Credentials verified. Excellent academic background and 5+ years of experience.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/doctors/{{doctor_id}}/verify",
              "host": ["{{base_url}}"],
              "path": ["admin", "doctors", "{{doctor_id}}", "verify"]
            }
          },
          "response": []
        },
        {
          "name": "3. Reject Doctor (Deny)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Credentials could not be verified. License has expired.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/doctors/{{doctor_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["admin", "doctors", "{{doctor_id}}", "reject"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "🔒 Account Lock/Unlock",
      "item": [
        {
          "name": "1. Lock Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Violation of terms: Inappropriate behavior and harassment of other users.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}/lock",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}", "lock"]
            }
          },
          "response": []
        },
        {
          "name": "2. Unlock Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}/unlock",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}", "unlock"]
            }
          },
          "response": []
        },
        {
          "name": "3. Get Lock History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/{{user_id}}/lock-history",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{user_id}}", "lock-history"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "⚠️ Violation Management",
      "item": [
        {
          "name": "1. Create Violation Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reportedUserId\": \"{{user_id}}\",\n  \"type\": \"harassment\",\n  \"reason\": \"Patient reported receiving abusive language from doctor in chat messages.\",\n  \"evidence\": \"https://example.com/screenshots/chat-abuse.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/violations",
              "host": ["{{base_url}}"],
              "path": ["admin", "violations"]
            }
          },
          "response": []
        },
        {
          "name": "2. Get All Violations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/violations?page=1&limit=10&status=pending&sortOrder=desc",
              "host": ["{{base_url}}"],
              "path": ["admin", "violations"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "pending"
                },
                {
                  "key": "sortOrder",
                  "value": "desc"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "3. Get Violation Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/violations/{{violation_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "violations", "{{violation_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "4. Add Violation Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Reviewed chat logs. Evidence confirms harassment. Recommended action: 30-day account suspension.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/violations/{{violation_id}}/note",
              "host": ["{{base_url}}"],
              "path": ["admin", "violations", "{{violation_id}}", "note"]
            }
          },
          "response": []
        },
        {
          "name": "5. Resolve Violation",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resolution\": \"Account banned for 30 days. Doctor account suspended pending review.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/violations/{{violation_id}}/resolve",
              "host": ["{{base_url}}"],
              "path": ["admin", "violations", "{{violation_id}}", "resolve"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "📅 Sessions Management",
      "item": [
        {
          "name": "1. Get All Sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/sessions?page=1&limit=20&status=&sortOrder=desc",
              "host": ["{{base_url}}"],
              "path": ["admin", "sessions"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": ""
                },
                {
                  "key": "sortOrder",
                  "value": "desc"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "2. Get Session Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/sessions/{{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "sessions", "{{session_id}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "📊 Dashboard",
      "item": [
        {
          "name": "1. Get System Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/dashboard/stats",
              "host": ["{{base_url}}"],
              "path": ["admin", "dashboard", "stats"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "doctor_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "violation_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "session_id",
      "value": "",
      "type": "string"
    }
  ]
}
