{
  "info": {
    "name": "Healthcare System - Sessions API",
    "description": "Complete Sessions API Collection with all endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "SESSIONS ENDPOINTS",
      "item": [
        {
          "name": "1. Create Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"type\": \"consultation\",\n  \"title\": \"Initial Consultation\",\n  \"description\": \"Patient complains about headaches and dizziness\",\n  \"scheduledAt\": \"2026-03-20T10:00:00Z\",\n  \"duration\": 30,\n  \"note\": \"First time visiting\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions"]
            }
          }
        },
        {
          "name": "2. Get All Sessions (with filters)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions?status=pending&type=consultation&page=1&limit=10&sortBy=scheduledAt&sortOrder=-1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions"],
              "query": [
                {
                  "key": "status",
                  "value": "pending",
                  "disabled": false
                },
                {
                  "key": "type",
                  "value": "consultation",
                  "disabled": false
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "10",
                  "disabled": false
                },
                {
                  "key": "sortBy",
                  "value": "scheduledAt",
                  "disabled": false
                },
                {
                  "key": "sortOrder",
                  "value": "-1",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "3. Get Upcoming Sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions/upcoming?days=7",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions", "upcoming"],
              "query": [
                {
                  "key": "days",
                  "value": "7",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "4. Get Session by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions/{{sessionId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions", "{{sessionId}}"]
            }
          }
        },
        {
          "name": "5. Update Session",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Follow-up Consultation\",\n  \"note\": \"Updated note\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions/{{sessionId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions", "{{sessionId}}"]
            }
          }
        },
        {
          "name": "6. Confirm Session (Doctor)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctorToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions/{{sessionId}}/confirm",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions", "{{sessionId}}", "confirm"]
            }
          }
        },
        {
          "name": "7. Start Session (Doctor)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctorToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions/{{sessionId}}/start",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions", "{{sessionId}}", "start"]
            }
          }
        },
        {
          "name": "8. Complete Session (Doctor)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{doctorToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"diagnosis\": \"Migraine headache\",\n  \"prescription\": \"Aspirin 500mg twice daily for 7 days\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions/{{sessionId}}/complete",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions", "{{sessionId}}", "complete"]
            }
          }
        },
        {
          "name": "9. Cancel Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cancelReason\": \"Patient has urgent work meeting\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions/{{sessionId}}/cancel",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions", "{{sessionId}}", "cancel"]
            }
          }
        },
        {
          "name": "10. Reschedule Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduledAt\": \"2026-03-22T14:00:00Z\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions/{{sessionId}}/reschedule",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions", "{{sessionId}}", "reschedule"]
            }
          }
        },
        {
          "name": "11. Delete Session",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patientToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/sessions/{{sessionId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "sessions", "{{sessionId}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "patientToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "doctorToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "doctorId",
      "value": "",
      "type": "string"
    },
    {
      "key": "patientId",
      "value": "",
      "type": "string"
    }
  ]
}
