# Normalize line endings to LF for all text files
* text=auto eol=lf

# Force LF for source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.ico  binary
