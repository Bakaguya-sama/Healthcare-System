{
  "info": {
    "name": "Healthcare System - Health Metrics API",
    "description": "Complete Health Metrics API Collection with all endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "HEALTH METRICS ENDPOINTS",
      "item": [
        {
          "name": "1. Create Metric",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"blood_pressure\",\n  \"value\": 120,\n  \"systolic\": 120,\n  \"diastolic\": 80,\n  \"unit\": \"mmHg\",\n  \"status\": \"normal\",\n  \"note\": \"Morning measurement after breakfast\",\n  \"recordedAt\": \"2026-03-16T08:00:00Z\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/health-metrics",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "health-metrics"]
            }
          }
        },
        {
          "name": "2. Get All Metrics (with filters)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/health-metrics?type=blood_pressure&status=normal&page=1&limit=10&sortBy=recordedAt&sortOrder=-1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "health-metrics"],
              "query": [
                {
                  "key": "type",
                  "value": "blood_pressure",
                  "disabled": false
                },
                {
                  "key": "status",
                  "value": "normal",
                  "disabled": false
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "10",
                  "disabled": false
                },
                {
                  "key": "sortBy",
                  "value": "recordedAt",
                  "disabled": false
                },
                {
                  "key": "sortOrder",
                  "value": "-1",
                  "disabled": false
                }
              ]
            }
          }
        },
        {
          "name": "3. Get Metric by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/health-metrics/METRIC_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "health-metrics", "METRIC_ID_HERE"]
            }
          }
        },
        {
          "name": "4. Get Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/health-metrics/statistics/blood_pressure",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "health-metrics", "statistics", "blood_pressure"]
            }
          }
        },
        {
          "name": "5. Get Alerts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/health-metrics/alerts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "health-metrics", "alerts"]
            }
          }
        },
        {
          "name": "6. Update Metric",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"normal\",\n  \"note\": \"Updated measurement after exercise\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/health-metrics/METRIC_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "health-metrics", "METRIC_ID_HERE"]
            }
          }
        },
        {
          "name": "7. Mark as Reviewed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/health-metrics/METRIC_ID_HERE/review",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "health-metrics", "METRIC_ID_HERE", "review"]
            }
          }
        },
        {
          "name": "8. Delete Metric",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/health-metrics/METRIC_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "health-metrics", "METRIC_ID_HERE"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ]
}
